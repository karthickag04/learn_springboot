<!DOCTYPE html>
<html>

<head>
    <title>Register</title>
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

<h2>User Registration</h2>

<form action="/register" method="post">

    Username

    <input type="text"
           name="username" id="username">

    <br><br>

    Password

    <input type="password"
           name="password" id="password">

    <br><br>

    Email

    <input type="email"
           name="email" id="email">

    <br><br>

    <input type="submit"
           value="Register">

</form>

</body>

</html>